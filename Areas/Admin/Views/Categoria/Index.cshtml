@model IEnumerable<AppWebSistemaComandasDigital.Dtos.CategoriaDTO>
@{
    ViewData["Title"] = "Categorías";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var confirmarId     = TempData["ConfirmarEliminacionId"] as int?;
    var confirmarNombre = TempData["ConfirmarEliminacionNombre"] as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-tags text-secondary me-2"></i>Categorías</h3>
        <p class="text-muted mb-0 small">Gestión de categorías del menú</p>
    </div>
    <a asp-action="Create" class="btn btn-success btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nueva categoría
    </a>
</div>

<div class="card p-0">
    <div class="table-toolbar">
        <div>
            <div class="fw-bold small">Categorías del menú</div>
            <div class="text-muted small">Busca por nombre, descripcion o estado</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <input id="filtroCategorias" class="form-control form-control-sm table-search" placeholder="Buscar categoría..." />
            <select id="filtroEstadoCategorias" class="form-select form-select-sm table-filter-select">
                <option value="">Todos los estados</option>
                <option value="activa">Activas</option>
                <option value="inactiva">Inactivas</option>
            </select>
        </div>
    </div>
    <div id="emptyCategoriasFilter" class="table-empty-filter">No hay categorías que coincidan con el filtro.</div>
    <div class="table-responsive">
        <table id="tablaCategorias" class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th class="text-center" style="width:100px">Estado</th>
                    <th class="text-end" style="width:130px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-2"></i>No hay categorías registradas.
                        </td>
                    </tr>
                }
                @foreach (var cat in Model)
                {
                    <tr data-filter-row>
                        <td class="text-muted small">@cat.Id</td>
                        <td class="fw-semibold">@cat.Nombre</td>
                        <td class="text-muted small">@(cat.Descripcion ?? "-")</td>
                        <td class="text-center">
                            @if (cat.Activa)
                            {
                                <span class="badge bg-success-subtle text-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary">Inactiva</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@cat.Id"
                               class="btn btn-sm btn-outline-primary action-btn me-1" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger action-btn"
                                    title="Eliminar"
                                    onclick="confirmarEliminar(@cat.Id, '@Html.Raw(cat.Nombre.Replace("'", "\\'"))')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div id="paginacionCategorias"></div>
</div>

<!-- Modal 1: Confirmar eliminación simple (sin platos) -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>Eliminar categoría
                </h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="small mb-0">¿Eliminar <strong id="nombreCategoria"></strong>? Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="formEliminar" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal 2: Categoría con platos - elegir entre desactivar o eliminar definitivamente -->
<div class="modal fade" id="modalOpciones" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-warning">
                    <i class="bi bi-exclamation-circle me-2"></i>Categoría con platos registrados
                </h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="small mb-3">
                    La categoría <strong id="nombreOpciones"></strong> tiene platos asociados en el historial.
                    ¿Qué deseas hacer?
                </p>
                <div class="d-grid gap-2">
                    <form id="formDesactivar" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-warning w-100 text-start">
                            <i class="bi bi-eye-slash me-2"></i>
                            <strong>Desactivar</strong>
                            <small class="d-block text-muted fw-normal mt-1">
                                La categoría se oculta del menú pero el historial de pedidos se conserva.
                            </small>
                        </button>
                    </form>
                    <form id="formForceDelete" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100 text-start">
                            <i class="bi bi-trash3 me-2"></i>
                            <strong>Eliminar definitivamente</strong>
                            <small class="d-block text-muted fw-normal mt-1">
                                Se elimina la categoría y todos sus platos del sistema. Esta acción no se puede deshacer.
                            </small>
                        </button>
                    </form>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function configurarFiltroTabla(searchId, selectId, tableId, emptyId, pagination) {
        const search = document.getElementById(searchId);
        const select = document.getElementById(selectId);
        const table = document.getElementById(tableId);
        const empty = document.getElementById(emptyId);
        if (!search || !table) return;

        const filtrar = () => {
            const q = search.value.trim().toLowerCase();
            const selected = select ? select.value : '';
            let visibles = 0;
            table.querySelectorAll('tbody tr[data-filter-row]').forEach(row => {
                const text = row.innerText.toLowerCase();
                const visible = (!q || text.includes(q)) && (!selected || text.includes(selected));
                row.classList.toggle('data-filter-hidden', !visible);
                if (visible) visibles++;
            });
            if (empty) empty.style.display = visibles === 0 ? 'block' : 'none';
            pagination?.render(true);
        };

        search.addEventListener('input', filtrar);
        if (select) select.addEventListener('change', filtrar);
    }

    const paginacionCategorias = crearPaginacionTabla({
        tableId: 'tablaCategorias',
        paginationId: 'paginacionCategorias',
        pageSize: 10,
        emptyId: 'emptyCategoriasFilter'
    });

    configurarFiltroTabla('filtroCategorias', 'filtroEstadoCategorias', 'tablaCategorias', 'emptyCategoriasFilter', paginacionCategorias);

    function confirmarEliminar(id, nombre) {
        document.getElementById('nombreCategoria').textContent = nombre;
        document.getElementById('formEliminar').action = `/Admin/Categoria/Delete/${id}`;
        new bootstrap.Modal(document.getElementById('modalEliminar')).show();
    }

    @if (confirmarId.HasValue)
    {
        <text>
        // Abrir modal de opciones automáticamente si el controller detectó platos
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('nombreOpciones').textContent = '@Html.Raw(confirmarNombre.Replace("'", "\\'"))';
            document.getElementById('formDesactivar').action   = `/Admin/Categoria/Desactivar/@confirmarId`;
            document.getElementById('formForceDelete').action  = `/Admin/Categoria/ForceDelete/@confirmarId`;
            new bootstrap.Modal(document.getElementById('modalOpciones')).show();
        });
        </text>
    }
</script>
}





