@model AppWebSistemaComandasDigital.Dtos.ConfiguracionRestauranteDTO
@{
    ViewData["Title"] = "Configuracion";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-sliders text-warning me-2"></i>Configuracion</h3>
        <p class="text-muted mb-0 small">Datos basicos del restaurante y parametros visibles del sistema</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card surface-card p-4">
            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="NombreRestaurante" class="form-label fw-semibold small">Nombre del restaurante</label>
                        <input asp-for="NombreRestaurante" class="form-control" />
                        <span asp-validation-for="NombreRestaurante" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Ruc" class="form-label fw-semibold small">RUC</label>
                        <input asp-for="Ruc" class="form-control" placeholder="Opcional" />
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Direccion" class="form-label fw-semibold small">Direccion</label>
                        <input asp-for="Direccion" class="form-control" placeholder="Av. Principal 123" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Telefono" class="form-label fw-semibold small">Telefono</label>
                        <input asp-for="Telefono" class="form-control" placeholder="+51 999 999 999" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Moneda" class="form-label fw-semibold small">Moneda</label>
                        <input asp-for="Moneda" class="form-control" />
                        <span asp-validation-for="Moneda" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="IgvPorcentaje" class="form-label fw-semibold small">IGV (%)</label>
                        <input asp-for="IgvPorcentaje" type="number" step="0.01" min="0" max="30" class="form-control" />
                        <span asp-validation-for="IgvPorcentaje" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="HorarioAtencion" class="form-label fw-semibold small">Horario de atencion</label>
                        <input asp-for="HorarioAtencion" class="form-control" placeholder="Lun-Dom 12:00 - 23:00" />
                    </div>
                    <div class="col-md-9">
                        <label asp-for="LogoUrl" class="form-label fw-semibold small">Logo URL</label>
                        <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="ColorMarca" class="form-label fw-semibold small">Color marca</label>
                        <input asp-for="ColorMarca" type="color" class="form-control form-control-color w-100" />
                        <span asp-validation-for="ColorMarca" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2 me-1"></i>Guardar configuracion
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card p-4 h-100">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="metric-icon" style="--metric-accent:@Model.ColorMarca">
                    @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" alt="Logo" style="width:100%;height:100%;object-fit:cover;border-radius:12px" />
                    }
                    else
                    {
                        <i class="bi bi-shop"></i>
                    }
                </div>
                <div>
                    <h5 class="fw-bold mb-0">@Model.NombreRestaurante</h5>
                    <small class="text-muted">@Model.HorarioAtencion</small>
                </div>
            </div>
            <div class="small text-muted">
                <div class="mb-2"><i class="bi bi-geo-alt me-2"></i>@(Model.Direccion ?? "Direccion no registrada")</div>
                <div class="mb-2"><i class="bi bi-telephone me-2"></i>@(Model.Telefono ?? "Telefono no registrado")</div>
                <div class="mb-2"><i class="bi bi-receipt me-2"></i>IGV @Model.IgvPorcentaje.ToString("F2")%</div>
                <div><i class="bi bi-currency-dollar me-2"></i>Moneda @Model.Moneda</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
