@model AppWebSistemaComandasDigital.Dtos.MesaCreateDTO
@{
    ViewData["Title"] = "Nueva Mesa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-plus-circle text-success me-2"></i>Nueva Mesa</h3>
        <p class="text-muted mb-0 small">Registra una nueva mesa en el restaurante</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Numero" class="form-label fw-semibold small">
                        Número de mesa <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Numero" class="form-control"
                           placeholder="Ej: 1, 2, A1, B2" autofocus />
                    <span asp-validation-for="Numero" class="text-danger small"></span>
                    <div class="form-text">Identificador único de la mesa.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="Capacidad" class="form-label fw-semibold small">
                        Capacidad <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="Capacidad" type="number" min="1" max="20"
                               class="form-control" placeholder="Ej: 4" />
                        <span class="input-group-text text-muted small">personas</span>
                    </div>
                    <span asp-validation-for="Capacidad" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check2 me-1"></i>Guardar mesa
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
