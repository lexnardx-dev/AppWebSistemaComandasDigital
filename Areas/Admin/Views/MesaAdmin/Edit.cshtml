@model AppWebSistemaComandasDigital.Dtos.MesaUpdateDTO
@{
    ViewData["Title"] = "Editar Mesa";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var mesaId = ViewBag.MesaId as int? ?? 0;
    var numero = ViewBag.Numero as string ?? "";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-pencil text-primary me-2"></i>Editar Mesa @numero</h3>
        <p class="text-muted mb-0 small">Modifica los datos de la mesa</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4">
            <form asp-action="Edit" asp-route-id="@mesaId" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Número de mesa</label>
                    <input class="form-control" value="@numero" disabled />
                    <div class="form-text">El número de mesa no se puede modificar.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Capacidad" class="form-label fw-semibold small">
                        Capacidad <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="Capacidad" type="number" min="1" max="20" class="form-control" />
                        <span class="input-group-text text-muted small">personas</span>
                    </div>
                    <span asp-validation-for="Capacidad" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Estado" class="form-label fw-semibold small">Estado</label>
                    <select asp-for="Estado" class="form-select"
                            asp-items="Html.GetEnumSelectList<AppWebSistemaComandasDigital.Models.EstadoMesa>()">
                    </select>
                    <span asp-validation-for="Estado" class="text-danger small"></span>
                    <div class="form-text">
                        <i class="bi bi-info-circle me-1"></i>
                        El estado se actualiza automáticamente con los pedidos.
                        Cámbialo solo si es necesario.
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2 me-1"></i>Guardar cambios
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
