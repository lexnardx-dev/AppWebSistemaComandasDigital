@model AppWebSistemaComandasDigital.Dtos.PlatoCreateDTO
@{
    ViewData["Title"] = "Nuevo Plato";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-plus-circle text-success me-2"></i>Nuevo Plato</h3>
        <p class="text-muted mb-0 small">Complete los datos para registrar el plato en el menú</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card p-4">
            <form asp-action="Crear" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold small">
                        Nombre <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Lomo saltado" autofocus />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label fw-semibold small">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="2"
                              placeholder="Descripción breve del plato (opcional)"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label asp-for="Precio" class="form-label fw-semibold small">
                            Precio (S/) <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text text-muted small">S/</span>
                            <input asp-for="Precio" type="number" step="0.5" min="0.5"
                                   class="form-control" placeholder="0.00" />
                        </div>
                        <div class="form-text">Use valores enteros o terminados en .50. Ej: 18 o 18.50.</div>
                        <span asp-validation-for="Precio" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="CategoriaId" class="form-label fw-semibold small">
                            Categoría <span class="text-danger">*</span>
                        </label>
                        <select asp-for="CategoriaId" class="form-select"
                                asp-items="@(ViewBag.Categorias as Microsoft.AspNetCore.Mvc.Rendering.SelectList)">
                            <option value="">— Seleccionar —</option>
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ImagenUrl" class="form-label fw-semibold small">URL de imagen</label>
                    <input asp-for="ImagenUrl" class="form-control" placeholder="https://ejemplo.com/imagen.jpg" />
                    <span asp-validation-for="ImagenUrl" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImagenArchivo" class="form-label fw-semibold small">Subir imagen</label>
                    <input asp-for="ImagenArchivo" type="file" accept="image/png,image/jpeg,image/webp" class="form-control" />
                    <div class="form-text">JPG, PNG o WebP. Maximo 5 MB.</div>
                    <span asp-validation-for="ImagenArchivo" class="text-danger small"></span>
                </div>

                <!-- Preview imagen -->
                <div id="previewContainer" class="mb-3 d-none">
                    <p class="form-label fw-semibold small mb-1">Vista previa</p>
                    <img id="previewImg" src="" alt="preview"
                         class="rounded border" style="height:100px;object-fit:cover;" />
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input asp-for="Disponible" class="form-check-input" role="switch" id="switchDisponible" />
                        <label class="form-check-label fw-semibold small" for="switchDisponible">
                            Disponible en el menú
                        </label>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check2 me-1"></i>Guardar plato
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Preview de imagen en tiempo real
        const urlInput = document.querySelector('input[name="ImagenUrl"]');
        const fileInput = document.querySelector('input[name="ImagenArchivo"]');
        const preview  = document.getElementById('previewContainer');
        const img      = document.getElementById('previewImg');

        urlInput.addEventListener('input', () => {
            const url = urlInput.value.trim();
            if (url) {
                img.src = url;
                preview.classList.remove('d-none');
                img.onerror = () => preview.classList.add('d-none');
            } else {
                preview.classList.add('d-none');
            }
        });

        fileInput.addEventListener('change', () => {
            const file = fileInput.files?.[0];
            if (!file) return;
            img.src = URL.createObjectURL(file);
            preview.classList.remove('d-none');
        });
    </script>
}
