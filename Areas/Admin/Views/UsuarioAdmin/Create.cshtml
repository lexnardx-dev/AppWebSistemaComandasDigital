@model AppWebSistemaComandasDigital.Areas.Admin.Controllers.UsuarioCreateVM
@{
    ViewData["Title"] = "Nuevo Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-person-plus text-success me-2"></i>Nuevo Usuario</h3>
        <p class="text-muted mb-0 small">Crea una cuenta para un mozo o personal de cocina</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">

            <div class="alert alert-info py-2 small mb-3">
                <i class="bi bi-info-circle me-1"></i>
                Solo puedes crear cuentas de <strong>Mozo</strong> y <strong>Cocina</strong>.
                Los mozos acceden por la <strong>app móvil</strong>.
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold small">
                        Nombre completo <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Nombre" class="form-control"
                           placeholder="Ej: Piero Delgado" autofocus />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold small">
                        Correo electrónico <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Email" type="email" class="form-control"
                           placeholder="usuario@restaurante.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RolId" class="form-label fw-semibold small">
                        Rol <span class="text-danger">*</span>
                    </label>
                    <select asp-for="RolId" class="form-select"
                            asp-items="@(ViewBag.Roles as Microsoft.AspNetCore.Mvc.Rendering.SelectList)">
                        <option value="">— Seleccionar rol —</option>
                    </select>
                    <span asp-validation-for="RolId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold small">
                        Contraseña <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" id="inputPass"
                               class="form-control" placeholder="Mínimo 8 caracteres" />
                        <button class="btn btn-outline-secondary" type="button"
                                onclick="togglePass()">
                            <i class="bi bi-eye" id="iconoPass"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                    <div class="form-text">El usuario podrá usar esta contraseña para iniciar sesión.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check2 me-1"></i>Crear usuario
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        function togglePass() {
            const input = document.getElementById('inputPass');
            const icono = document.getElementById('iconoPass');
            const visible = input.type === 'text';
            input.type = visible ? 'password' : 'text';
            icono.className = visible ? 'bi bi-eye' : 'bi bi-eye-slash';
        }
    </script>
}
