@model AppWebSistemaComandasDigital.Dtos.VentasDashboardDTO
@using System.Globalization
@using System.Text.Json
@{
    ViewData["Title"] = "Ventas";

    const int RankingPerPage = 5;

    var hoy = DateTime.Today;
    var inicioSemana = hoy.AddDays(-(int)hoy.DayOfWeek + (hoy.DayOfWeek == DayOfWeek.Sunday ? -6 : 1));
    var inicioMes = new DateTime(hoy.Year, hoy.Month, 1);
    var filtroDesde = Model.Filtro.Desde?.Date;
    var filtroHasta = Model.Filtro.Hasta?.Date;
    var filtroHoyActivo = filtroDesde == hoy && filtroHasta == hoy;
    var filtroSemanaActivo = filtroDesde == inicioSemana && filtroHasta == hoy;
    var filtroMesActivo = filtroDesde == inicioMes && filtroHasta == hoy;

    var evolucionLabels = Model.EvolucionVentas.Select(v => v.Etiqueta).ToList();
    var evolucionTotales = Model.EvolucionVentas.Select(v => v.Total).ToList();
    var evolucionPedidos = Model.EvolucionVentas.Select(v => v.Pedidos).ToList();

    var categoriaLabels = Model.VentasPorCategoria.Select(c => c.Nombre).ToList();
    var categoriaTotales = Model.VentasPorCategoria.Select(c => c.Total).ToList();
    var mozoLabels = Model.VentasPorMozo.Select(m => m.Nombre).ToList();
    var mozoTotales = Model.VentasPorMozo.Select(m => m.Total).ToList();
    var horaLabels = Model.VentasPorHora.Select(h => h.Etiqueta).ToList();
    var horaTotales = Model.VentasPorHora.Select(h => h.Total).ToList();
    var diaLabels = Model.VentasPorDiaSemana.Select(d => d.Dia).ToList();
    var diaTotales = Model.VentasPorDiaSemana.Select(d => d.Total).ToList();

    var totalRanking = Model.TopPlatos.Sum(p => p.Total);
    var totalRankingSeguro = totalRanking <= 0 ? 1 : totalRanking;
    var comparativoClass = Model.Comparativo.VariacionPorcentual > 0 ? "positive" : Model.Comparativo.VariacionPorcentual < 0 ? "negative" : "neutral";
    var comparativoIcon = Model.Comparativo.VariacionPorcentual > 0 ? "bi-arrow-up-right" : Model.Comparativo.VariacionPorcentual < 0 ? "bi-arrow-down-right" : "bi-dash-lg";
}

<div class="page-heading">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow text-success me-2"></i>Ventas</h3>
        <p class="page-subtitle">Resumen comercial basado solo en pedidos entregados</p>
    </div>
    <div class="quick-filters">
        <a class="quick-filter @(filtroHoyActivo ? "active" : "")" asp-action="Index" asp-route-desde="@hoy.ToString("yyyy-MM-dd")" asp-route-hasta="@hoy.ToString("yyyy-MM-dd")"><i class="bi bi-calendar-day"></i>Hoy</a>
        <a class="quick-filter @(filtroSemanaActivo ? "active" : "")" asp-action="Index" asp-route-desde="@inicioSemana.ToString("yyyy-MM-dd")" asp-route-hasta="@hoy.ToString("yyyy-MM-dd")"><i class="bi bi-calendar-week"></i>Semana</a>
        <a class="quick-filter @(filtroMesActivo ? "active" : "")" asp-action="Index" asp-route-desde="@inicioMes.ToString("yyyy-MM-dd")" asp-route-hasta="@hoy.ToString("yyyy-MM-dd")"><i class="bi bi-calendar3"></i>Mes</a>
    </div>
</div>

<form method="get" class="card surface-card p-3 mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-6 col-md-3">
            <label class="form-label small fw-semibold">Desde</label>
            <input type="date" name="desde" value="@Model.Filtro.Desde?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label small fw-semibold">Hasta</label>
            <input type="date" name="hasta" value="@Model.Filtro.Hasta?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100" type="submit">
                <i class="bi bi-funnel me-1"></i>Aplicar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary action-btn" title="Limpiar">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-success">
            <div class="metric-icon"><i class="bi bi-cash-coin"></i></div>
            <div>
                <p>Total vendido</p>
                <strong>S/ @Model.TotalVendido.ToString("F2")</strong>
                <span>Pedidos entregados</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-primary">
            <div class="metric-icon"><i class="bi bi-receipt"></i></div>
            <div>
                <p>Ventas cerradas</p>
                <strong>@Model.PedidosEntregados</strong>
                <span>Comandas entregadas</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-warning">
            <div class="metric-icon"><i class="bi bi-ticket-perforated"></i></div>
            <div>
                <p>Ticket promedio</p>
                <strong>S/ @Model.TicketPromedio.ToString("F2")</strong>
                <span>Por pedido entregado</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-info">
            <div class="metric-icon"><i class="bi bi-egg-fried"></i></div>
            <div>
                <p>Platos vendidos</p>
                <strong>@Model.PlatosVendidos</strong>
                <span>Unidades entregadas</span>
            </div>
        </div>
    </div>
</div>

<div class="sales-dashboard-grid">
    <section class="chart-panel executive-panel executive-panel-wide">
        <div class="analytics-card-title">
            <span><i class="bi bi-graph-up text-success me-2"></i>Evoluci&oacute;n de ventas</span>
            <small class="text-muted">Ventas por d&iacute;a vs. pedidos entregados</small>
        </div>
        <div class="chart-box chart-box-lg">
            <canvas id="ventasComboChart"></canvas>
        </div>
    </section>

    <section class="chart-panel executive-panel comparison-panel @comparativoClass">
        <div class="analytics-card-title">
            <span><i class="bi bi-arrow-left-right text-primary me-2"></i>Comparativo</span>
            <small class="text-muted">@Model.Comparativo.PeriodoAnterior</small>
        </div>
        <div class="comparison-value">
            <i class="bi @comparativoIcon"></i>
            <strong>@Math.Abs(Model.Comparativo.VariacionPorcentual).ToString("F1")%</strong>
            <span>@Model.Comparativo.Tendencia</span>
        </div>
        <div class="comparison-grid">
            <div>
                <span>Periodo actual</span>
                <strong>S/ @Model.Comparativo.TotalActual.ToString("F2")</strong>
                <small>@Model.Comparativo.PedidosActuales pedidos</small>
            </div>
            <div>
                <span>Periodo anterior</span>
                <strong>S/ @Model.Comparativo.TotalAnterior.ToString("F2")</strong>
                <small>@Model.Comparativo.PedidosAnteriores pedidos</small>
            </div>
        </div>
    </section>

    <section class="chart-panel executive-panel">
        <div class="analytics-card-title">
            <span><i class="bi bi-pie-chart text-primary me-2"></i>Ventas por categor&iacute;a</span>
            <small class="text-muted">Participaci&oacute;n comercial</small>
        </div>
        <div class="chart-box chart-box-md">
            <canvas id="categoriaDonaChart"></canvas>
        </div>
        <div class="category-insight-list">
            @foreach (var categoria in Model.VentasPorCategoria.Take(4))
            {
                var porcentaje = categoria.Total * 100 / Math.Max(1, Model.TotalVendido);
                <div class="category-insight-item">
                    <span>@categoria.Nombre</span>
                    <strong>S/ @categoria.Total.ToString("F2")</strong>
                    <small>@porcentaje.ToString("F1")% &middot; @categoria.Cantidad unidades</small>
                </div>
            }
            @if (!Model.VentasPorCategoria.Any())
            {
                <div class="empty-state compact-empty-state">
                    <i class="bi bi-inbox"></i>
                    <span>No hay ventas por categoria en este periodo.</span>
                </div>
            }
        </div>
    </section>

    <section class="chart-panel executive-panel">
        <div class="analytics-card-title">
            <span><i class="bi bi-person-lines-fill text-info me-2"></i>Ventas por mozo</span>
            <small class="text-muted">Productividad comercial</small>
        </div>
        <div class="chart-box chart-box-md">
            <canvas id="mozoChart"></canvas>
        </div>
    </section>

    <section class="chart-panel executive-panel executive-panel-wide ranking-panel">
        <div class="analytics-card-title">
            <span><i class="bi bi-trophy text-warning me-2"></i>Ranking comercial</span>
            <small class="text-muted">Productos por facturaci&oacute;n</small>
        </div>
        @if (Model.TopPlatos.Any())
        {
            <div class="ranking-list">
                @foreach (var item in Model.TopPlatos.Select((plato, index) => new { plato, index }))
                {
                    var width = (item.plato.Total * 100 / totalRankingSeguro).ToString("0.##", CultureInfo.InvariantCulture);
                    var participacion = item.plato.Total * 100 / totalRankingSeguro;
                    <div class="ranking-row ranking-page-item">
                        <div class="ranking-index">#@(item.index + 1)</div>
                        <div class="ranking-content">
                            <div class="ranking-line">
                                <div>
                                    <strong>@item.plato.Nombre</strong>
                                    <span>@item.plato.Cantidad unidades &middot; @participacion.ToString("F1")% del total vendido</span>
                                </div>
                                <strong class="ranking-total">S/ @item.plato.Total.ToString("F2")</strong>
                            </div>
                            <div class="ranking-meter" aria-label="@item.plato.Nombre: @participacion.ToString("F1")% del total vendido">
                                <div style="width:@width%"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TopPlatos.Count > RankingPerPage)
            {
                <div class="top-pagination mt-3">
                    <button type="button" id="btnPrevRanking" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span id="rankingPageIndicator" class="mx-3 fw-semibold"></span>
                    <button type="button" id="btnNextRanking" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            }
        }
        else
        {
            <div class="empty-state compact-empty-state">
                <i class="bi bi-inbox"></i>
                <span>No hay productos vendidos en este periodo.</span>
            </div>
        }
    </section>

    <section class="chart-panel executive-panel">
        <div class="analytics-card-title">
            <span><i class="bi bi-clock text-secondary me-2"></i>Ventas por hora</span>
            <small class="text-muted">Horas de mayor movimiento</small>
        </div>
        <div class="chart-box chart-box-sm">
            <canvas id="horaChart"></canvas>
        </div>
    </section>

    <section class="chart-panel executive-panel">
        <div class="analytics-card-title">
            <span><i class="bi bi-calendar-week text-warning me-2"></i>Ventas por d&iacute;a</span>
            <small class="text-muted">Movimiento semanal</small>
        </div>
        <div class="chart-box chart-box-sm">
            <canvas id="diaSemanaChart"></canvas>
        </div>
    </section>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
    const evolucionLabels = @Html.Raw(JsonSerializer.Serialize(evolucionLabels));
    const evolucionTotales = @Html.Raw(JsonSerializer.Serialize(evolucionTotales));
    const evolucionPedidos = @Html.Raw(JsonSerializer.Serialize(evolucionPedidos));
    const categoriaLabels = @Html.Raw(JsonSerializer.Serialize(categoriaLabels));
    const categoriaTotales = @Html.Raw(JsonSerializer.Serialize(categoriaTotales));
    const mozoLabels = @Html.Raw(JsonSerializer.Serialize(mozoLabels));
    const mozoTotales = @Html.Raw(JsonSerializer.Serialize(mozoTotales));
    const horaLabels = @Html.Raw(JsonSerializer.Serialize(horaLabels));
    const horaTotales = @Html.Raw(JsonSerializer.Serialize(horaTotales));
    const diaLabels = @Html.Raw(JsonSerializer.Serialize(diaLabels));
    const diaTotales = @Html.Raw(JsonSerializer.Serialize(diaTotales));

    const chartColors = ['#2563eb', '#059669', '#f59e0b', '#0ea5e9', '#ef4444', '#7c3aed', '#14b8a6'];
    const money = value => `S/ ${Number(value || 0).toFixed(2)}`;

    const baseScales = {
        x: { grid: { display: false }, ticks: { color: '#64748b' } },
        y: { beginAtZero: true, grid: { color: '#eef2f7' }, ticks: { color: '#64748b' } }
    };

    new Chart(document.getElementById('ventasComboChart'), {
        data: {
            labels: evolucionLabels.length ? evolucionLabels : ['Sin datos'],
            datasets: [
                {
                    type: 'bar',
                    label: 'Ventas',
                    data: evolucionTotales.length ? evolucionTotales : [0],
                    backgroundColor: 'rgba(5, 150, 105, .18)',
                    borderColor: '#059669',
                    borderWidth: 1,
                    borderRadius: 8,
                    yAxisID: 'y'
                },
                {
                    type: 'line',
                    label: 'Pedidos',
                    data: evolucionPedidos.length ? evolucionPedidos : [0],
                    borderColor: '#2563eb',
                    backgroundColor: '#2563eb',
                    borderWidth: 3,
                    tension: .35,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    yAxisID: 'y1'
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 12, color: '#334155' } },
                tooltip: {
                    callbacks: {
                        label: context => context.dataset.label === 'Ventas'
                            ? `Ventas: ${money(context.parsed.y)}`
                            : `Pedidos: ${context.parsed.y}`
                    }
                }
            },
            scales: {
                x: baseScales.x,
                y: {
                    ...baseScales.y,
                    ticks: { color: '#64748b', callback: value => money(value) }
                },
                y1: {
                    beginAtZero: true,
                    position: 'right',
                    grid: { drawOnChartArea: false },
                    ticks: { color: '#64748b', precision: 0 }
                }
            }
        }
    });

    new Chart(document.getElementById('categoriaDonaChart'), {
        type: 'doughnut',
        data: {
            labels: categoriaLabels.length ? categoriaLabels : ['Sin datos'],
            datasets: [{
                data: categoriaTotales.length ? categoriaTotales : [1],
                backgroundColor: categoriaLabels.length ? chartColors : ['#e5e7eb'],
                borderWidth: 0,
                hoverOffset: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '68%',
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 10, color: '#334155' } },
                tooltip: { callbacks: { label: context => `${context.label}: ${money(context.raw)}` } }
            }
        }
    });

    new Chart(document.getElementById('mozoChart'), {
        type: 'bar',
        data: {
            labels: mozoLabels.length ? mozoLabels : ['Sin datos'],
            datasets: [{
                label: 'Ventas',
                data: mozoTotales.length ? mozoTotales : [0],
                backgroundColor: 'rgba(37, 99, 235, .16)',
                borderColor: '#2563eb',
                borderWidth: 1,
                borderRadius: 8
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: context => money(context.raw) } }
            },
            scales: {
                x: { beginAtZero: true, grid: { color: '#eef2f7' }, ticks: { color: '#64748b', callback: value => money(value) } },
                y: { grid: { display: false }, ticks: { color: '#334155' } }
            }
        }
    });

    new Chart(document.getElementById('horaChart'), {
        type: 'bar',
        data: {
            labels: horaLabels.length ? horaLabels : ['Sin datos'],
            datasets: [{
                label: 'Ventas',
                data: horaTotales.length ? horaTotales : [0],
                backgroundColor: 'rgba(14, 165, 233, .18)',
                borderColor: '#0ea5e9',
                borderWidth: 1,
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: context => money(context.raw) } }
            },
            scales: baseScales
        }
    });

    new Chart(document.getElementById('diaSemanaChart'), {
        type: 'bar',
        data: {
            labels: diaLabels.length ? diaLabels : ['Sin datos'],
            datasets: [{
                label: 'Ventas',
                data: diaTotales.length ? diaTotales : [0],
                backgroundColor: 'rgba(245, 158, 11, .22)',
                borderColor: '#f59e0b',
                borderWidth: 1,
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: context => money(context.raw) } }
            },
            scales: baseScales
        }
    });

    const RANKING_PER_PAGE = @RankingPerPage;
    const rankingRows = document.querySelectorAll('.ranking-list .ranking-page-item');

    if (rankingRows.length) {
        let currentRankingPage = 1;
        const totalRankingPages = Math.max(1, Math.ceil(rankingRows.length / RANKING_PER_PAGE));
        const indicator = document.getElementById('rankingPageIndicator');
        const prev = document.getElementById('btnPrevRanking');
        const next = document.getElementById('btnNextRanking');

        function renderRankingPage() {
            rankingRows.forEach((item, index) => {
                const start = (currentRankingPage - 1) * RANKING_PER_PAGE;
                const end = start + RANKING_PER_PAGE;
                item.style.display = index >= start && index < end ? '' : 'none';
            });
            if (indicator) indicator.textContent = `Pagina ${currentRankingPage} de ${totalRankingPages}`;
            if (prev) prev.disabled = currentRankingPage === 1;
            if (next) next.disabled = currentRankingPage === totalRankingPages;
        }

        prev?.addEventListener('click', () => {
            if (currentRankingPage > 1) {
                currentRankingPage--;
                renderRankingPage();
            }
        });

        next?.addEventListener('click', () => {
            if (currentRankingPage < totalRankingPages) {
                currentRankingPage++;
                renderRankingPage();
            }
        });

        renderRankingPage();
    }
</script>
}