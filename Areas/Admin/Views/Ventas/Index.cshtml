@model AppWebSistemaComandasDigital.Dtos.VentasDashboardDTO
@using System.Text.Json
@{
    ViewData["Title"] = "Ventas";

    var hoy = DateTime.Today;
    var inicioSemana = hoy.AddDays(-(int)hoy.DayOfWeek + (hoy.DayOfWeek == DayOfWeek.Sunday ? -6 : 1));
    var inicioMes = new DateTime(hoy.Year, hoy.Month, 1);
    var filtroDesde = Model.Filtro.Desde?.Date;
    var filtroHasta = Model.Filtro.Hasta?.Date;
    var filtroHoyActivo = filtroDesde == hoy && filtroHasta == hoy;
    var filtroSemanaActivo = filtroDesde == inicioSemana && filtroHasta == hoy;
    var filtroMesActivo = filtroDesde == inicioMes && filtroHasta == hoy;

    var topMaxCantidad = Model.TopPlatos.Any() ? Math.Max(1, Model.TopPlatos.Max(p => p.Cantidad)) : 1;
    var topTotalUnidades = Math.Max(1, Model.TopPlatos.Sum(p => p.Cantidad));

    var topPlatosRestantes = Model.TopPlatos.Skip(1).ToList();

    var ventasPorDia = Model.UltimasVentas
        .GroupBy(v => v.FechaCreacion.Date)
        .OrderBy(g => g.Key)
        .Select(g => new { Fecha = g.Key.ToString("dd/MM"), Total = g.Sum(x => x.Total) })
        .ToList();
    var ventasLabels = ventasPorDia.Select(v => v.Fecha).ToList();
    var ventasTotales = ventasPorDia.Select(v => v.Total).ToList();
}

<div class="page-heading">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow text-success me-2"></i>Ventas</h3>
        <p class="page-subtitle">Resumen comercial basado solo en pedidos entregados</p>
    </div>
    <div class="quick-filters">
        <a class="quick-filter @(filtroHoyActivo ? "active" : "")" asp-action="Index" asp-route-desde="@hoy.ToString("yyyy-MM-dd")" asp-route-hasta="@hoy.ToString("yyyy-MM-dd")"><i class="bi bi-calendar-day"></i>Hoy</a>
        <a class="quick-filter @(filtroSemanaActivo ? "active" : "")" asp-action="Index" asp-route-desde="@inicioSemana.ToString("yyyy-MM-dd")" asp-route-hasta="@hoy.ToString("yyyy-MM-dd")"><i class="bi bi-calendar-week"></i>Semana</a>
        <a class="quick-filter @(filtroMesActivo ? "active" : "")" asp-action="Index" asp-route-desde="@inicioMes.ToString("yyyy-MM-dd")" asp-route-hasta="@hoy.ToString("yyyy-MM-dd")"><i class="bi bi-calendar3"></i>Mes</a>
    </div>
</div>

<form method="get" class="card surface-card p-3 mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-6 col-md-3">
            <label class="form-label small fw-semibold">Desde</label>
            <input type="date" name="desde" value="@Model.Filtro.Desde?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label small fw-semibold">Hasta</label>
            <input type="date" name="hasta" value="@Model.Filtro.Hasta?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100" type="submit">
                <i class="bi bi-funnel me-1"></i>Aplicar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary action-btn" title="Limpiar">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-success">
            <div class="metric-icon"><i class="bi bi-cash-coin"></i></div>
            <div>
                <p>Total vendido</p>
                <strong>S/ @Model.TotalVendido.ToString("F2")</strong>
                <span>Pedidos entregados</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-primary">
            <div class="metric-icon"><i class="bi bi-receipt"></i></div>
            <div>
                <p>Ventas cerradas</p>
                <strong>@Model.PedidosEntregados</strong>
                <span>Comandas entregadas</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-warning">
            <div class="metric-icon"><i class="bi bi-ticket-perforated"></i></div>
            <div>
                <p>Ticket promedio</p>
                <strong>S/ @Model.TicketPromedio.ToString("F2")</strong>
                <span>Por pedido entregado</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-info">
            <div class="metric-icon"><i class="bi bi-egg-fried"></i></div>
            <div>
                <p>Platos vendidos</p>
                <strong>@Model.PlatosVendidos</strong>
                <span>Unidades entregadas</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-7">
        <div class="chart-panel h-100">
            <div class="analytics-card-title">
                <span><i class="bi bi-graph-up text-success me-2"></i>Evolución de ventas</span>
                <small class="text-muted">Según ventas cerradas visibles</small>
            </div>
            <div class="chart-box">
                <canvas id="ventasLineChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-5">
        <div class="chart-panel top-products-panel h-100">
            <div class="analytics-card-title">
                <span><i class="bi bi-bar-chart-fill text-primary me-2"></i>Platos más vendidos</span>
                <small class="text-muted">Unidades</small>
            </div>

            @if (Model.TopPlatos.Any())
            {
                var lider = Model.TopPlatos.First();
                var liderPct = Math.Round((double)lider.Cantidad * 100 / topTotalUnidades);
                <div class="top-product-hero">
                    <div class="top-product-rank">#1</div>
                    <div class="top-product-main">
                        <span>Plato líder</span>
                        <strong>@lider.Nombre</strong>
                        <small>@lider.Cantidad unidades · @liderPct% del top vendido</small>
                    </div>
                    <div class="top-product-total">S/ @lider.Total.ToString("F2")</div>
                </div>

                @* <div class="top-product-list">
                    @foreach (var item in Model.TopPlatos.Select((plato, index) => new { plato, index }))
                    {
                        var pct = Math.Round((double)item.plato.Cantidad * 100 / topMaxCantidad);
                        var share = Math.Round((double)item.plato.Cantidad * 100 / topTotalUnidades);
                        <div class="top-product-row">
                            <div class="top-product-index">@(item.index + 1)</div>
                            <div class="top-product-info">
                                <div class="top-product-line">
                                    <span>@item.plato.Nombre</span>
                                    <strong>@item.plato.Cantidad u.</strong>
                                </div>
                                <div class="top-product-meter" aria-label="@item.plato.Nombre: @item.plato.Cantidad unidades">
                                    <div style="width:@pct%"></div>
                                </div>
                                <div class="top-product-meta">
                                    <span>@share% del ranking</span>
                                    <span>S/ @item.plato.Total.ToString("F2")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div> *@

                <div id="topProductsContainer" class="top-product-list">

    @foreach (var item in topPlatosRestantes.Select((plato, index) => new { plato, index }))
    {
        var pct = Math.Round((double)item.plato.Cantidad * 100 / topMaxCantidad);
        var share = Math.Round((double)item.plato.Cantidad * 100 / topTotalUnidades);

        <div class="top-product-row product-page-item">

            <div class="top-product-index">
                @(item.index + 2)
            </div>

            <div class="top-product-info">

                <div class="top-product-line">
                    <span>@item.plato.Nombre</span>
                    <strong>@item.plato.Cantidad u.</strong>
                </div>

                <div class="top-product-meter"
                     aria-label="@item.plato.Nombre: @item.plato.Cantidad unidades">
                    <div style="width:@pct%"></div>
                </div>

                <div class="top-product-meta">
                    <span>@share% del ranking</span>
                    <span>S/ @item.plato.Total.ToString("F2")</span>
                </div>

            </div>

        </div>
    }

</div>

@if (topPlatosRestantes.Count > 3)
{
    <div class="top-pagination mt-3">

        <button id="btnPrevTop"
                class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-chevron-left"></i>
        </button>

        <span id="topPageIndicator"
              class="mx-3 fw-semibold">
        </span>

        <button id="btnNextTop"
                class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-chevron-right"></i>
        </button>

    </div>
}
            }
            else
            {
                <div class="empty-state compact-empty-state">
                    <i class="bi bi-inbox"></i>
                    <span>No hay ventas entregadas en este periodo.</span>
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card p-0 h-100">
            <div class="card-header bg-transparent px-3 py-3">
                <i class="bi bi-trophy text-warning me-2"></i>
                <span class="fw-bold">Ranking comercial</span>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var plato in Model.TopPlatos)
                {
                    var maxCantidad = Model.TopPlatos.Any() ? Math.Max(1, Model.TopPlatos.Max(p => p.Cantidad)) : 1;
                    var pct = Math.Round((double)plato.Cantidad * 100 / maxCantidad);
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <div class="fw-semibold">@plato.Nombre</div>
                                <small class="text-muted">@plato.Cantidad unidades</small>
                            </div>
                            <span class="fw-bold text-success">S/ @plato.Total.ToString("F2")</span>
                        </div>
                        <div class="ops-progress" style="height:8px">
                            <div class="ops-segment ops-cooking" style="width:@pct%"></div>
                        </div>
                    </div>
                }
                @if (!Model.TopPlatos.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <span>No hay ventas entregadas en este periodo.</span>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card p-0 h-100">
            <div class="card-header bg-transparent px-3 py-3">
                <i class="bi bi-clock-history text-secondary me-2"></i>
                <span class="fw-bold">Últimas ventas</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-modern align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Mesa</th>
                            <th>Mozo</th>
                            <th>Fecha</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var venta in Model.UltimasVentas)
                        {
                            <tr>
                                <td class="fw-bold text-muted">#@venta.Id</td>
                                <td>Mesa @venta.MesaNumero</td>
                                <td>@venta.UsuarioNombre</td>
                                <td class="text-muted small">@venta.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end fw-bold text-success">S/ @venta.Total.ToString("F2")</td>
                            </tr>
                        }
                        @if (!Model.UltimasVentas.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">Sin ventas cerradas.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
    const ventasLabels = @Html.Raw(JsonSerializer.Serialize(ventasLabels));
    const ventasTotales = @Html.Raw(JsonSerializer.Serialize(ventasTotales));

    const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { display: false }, ticks: { color: '#64748b' } },
            y: { beginAtZero: true, grid: { color: '#eef2f7' }, ticks: { color: '#64748b' } }
        }
    };

    new Chart(document.getElementById('ventasLineChart'), {
        type: 'line',
        data: {
            labels: ventasLabels.length ? ventasLabels : ['Sin datos'],
            datasets: [{
                data: ventasTotales.length ? ventasTotales : [0],
                borderColor: '#059669',
                backgroundColor: 'rgba(5,150,105,.14)',
                borderWidth: 3,
                tension: .35,
                fill: true,
                pointRadius: 4,
                pointBackgroundColor: '#059669'
            }]
        },
        options: commonOptions
    });
    const ITEMS_PER_PAGE = 3;

const productRows =
    document.querySelectorAll(".product-page-item");

if (productRows.length) {

    let currentPage = 1;

    const totalPages =
        Math.ceil(productRows.length / ITEMS_PER_PAGE);

    const indicator =
        document.getElementById("topPageIndicator");

    const prev =
        document.getElementById("btnPrevTop");

    const next =
        document.getElementById("btnNextTop");

    function renderPage() {

        productRows.forEach((item, index) => {

            const start = (currentPage - 1) * ITEMS_PER_PAGE;
            const end = start + ITEMS_PER_PAGE;

            item.style.display =
                index >= start && index < end
                    ? ""
                    : "none";

        });

        if (indicator)
            indicator.textContent =
                `Página ${currentPage} de ${totalPages}`;

        if (prev)
            prev.disabled = currentPage === 1;

        if (next)
            next.disabled = currentPage === totalPages;
    }

    prev?.addEventListener("click", () => {

        if (currentPage > 1) {

            currentPage--;

            renderPage();

        }

    });

    next?.addEventListener("click", () => {

        if (currentPage < totalPages) {

            currentPage++;

            renderPage();

        }

    });

    renderPage();

}
</script>
}
