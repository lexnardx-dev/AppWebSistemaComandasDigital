@using AppWebSistemaComandasDigital.Dtos
@using System.Text.Json
@{
    ViewData["Title"] = "Inicio";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var rol = User.FindFirst("rol_nombre")?.Value ?? "";
    var nombre = User.Identity?.Name ?? "Usuario";

    var totalMesas = (int)(ViewBag.TotalMesas ?? 0);
    var mesasLibres = (int)(ViewBag.MesasLibres ?? 0);
    var mesasOcupadas = (int)(ViewBag.MesasOcupadas ?? 0);
    var pedidosPendientes = (int)(ViewBag.PedidosPendientes ?? 0);
    var pedidosEnCocina = (int)(ViewBag.PedidosEnCocina ?? 0);
    var pedidosListos = (int)(ViewBag.PedidosListos ?? 0);
    var totalVendido = (decimal)(ViewBag.TotalVendido ?? 0m);
    var totalPlatos = (int)(ViewBag.TotalPlatos ?? 0);
    var ultimosPedidos = ViewBag.UltimosPedidos as List<PedidoDTO> ?? [];
    var pedidosPorHora = ViewBag.PedidosPorHora ?? new List<object>();

    var pedidosActivos = pedidosPendientes + pedidosEnCocina + pedidosListos;
    var pctLibres = totalMesas == 0 ? 0 : (int)Math.Round((double)mesasLibres * 100 / totalMesas);
    var pctOcupadas = totalMesas == 0 ? 0 : 100 - pctLibres;
    var pctPendientes = pedidosActivos == 0 ? 0 : (int)Math.Round((double)pedidosPendientes * 100 / pedidosActivos);
    var pctCocina = pedidosActivos == 0 ? 0 : (int)Math.Round((double)pedidosEnCocina * 100 / pedidosActivos);
    var pctListos = pedidosActivos == 0 ? 0 : Math.Max(0, 100 - pctPendientes - pctCocina);
}

<div class="home-hero mb-4">
    <div>
        <div class="text-uppercase text-muted fw-bold small mb-2">Panel operativo</div>
        <h2 class="fw-bold mb-1">Bienvenido, @nombre</h2>
        <p class="text-muted mb-0">
            @DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-PE"))
        </p>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
        <span class="badge rounded-pill bg-warning text-dark px-3 py-2">@rol</span>
        <span class="badge rounded-pill bg-success px-3 py-2">
            <i class="bi bi-circle-fill me-1 status-dot"></i>En linea
        </span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-primary">
            <div class="metric-icon"><i class="bi bi-receipt-cutoff"></i></div>
            <div>
                <p>Pedidos activos</p>
                <strong>@pedidosActivos</strong>
                <span>@pedidosPendientes pendientes</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-success">
            <div class="metric-icon"><i class="bi bi-grid-3x3-gap"></i></div>
            <div>
                <p>Mesas libres</p>
                <strong>@mesasLibres / @totalMesas</strong>
                <span>@mesasOcupadas ocupadas</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-warning">
            <div class="metric-icon"><i class="bi bi-fire"></i></div>
            <div>
                <p>En cocina</p>
                <strong>@pedidosEnCocina</strong>
                <span>@pedidosListos listos para servir</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="metric-card metric-info">
            <div class="metric-icon"><i class="bi bi-cash-coin"></i></div>
            <div>
                <p>Vendido</p>
                <strong>S/ @totalVendido.ToString("F2")</strong>
                <span>@totalPlatos platos en menu</span>
            </div>
        </div>
    </div>
</div>

<div class="analytics-grid home-analytics-grid mb-4">
    <div class="analytics-card">
        <div class="analytics-card-title">
            <span><i class="bi bi-activity text-primary me-2"></i>Lectura rapida del turno</span>
            <span class="badge rounded-pill bg-light text-dark">Tiempo real</span>
        </div>
        <div class="ops-bars">
            <div>
                <div class="ops-bar-label"><span>Ocupacion de mesas</span><strong>@pctOcupadas%</strong></div>
                <div class="ops-progress" aria-label="Ocupacion de mesas">
                    <div class="ops-segment ops-free" style="width:@pctLibres%"></div>
                    <div class="ops-segment ops-busy" style="width:@pctOcupadas%"></div>
                </div>
                <div class="d-flex gap-3 mt-2 small text-muted">
                    <span><i class="bi bi-circle-fill text-success me-1"></i>@mesasLibres libres</span>
                    <span><i class="bi bi-circle-fill text-danger me-1"></i>@mesasOcupadas ocupadas</span>
                </div>
            </div>
            <div>
                <div class="ops-bar-label"><span>Flujo de pedidos activos</span><strong>@pedidosActivos comandas</strong></div>
                <div class="ops-progress" aria-label="Estados de pedidos">
                    <div class="ops-segment ops-pending" style="width:@pctPendientes%"></div>
                    <div class="ops-segment ops-cooking" style="width:@pctCocina%"></div>
                    <div class="ops-segment ops-ready" style="width:@pctListos%"></div>
                </div>
                <div class="d-flex flex-wrap gap-3 mt-2 small text-muted">
                    <span><i class="bi bi-circle-fill text-secondary me-1"></i>@pedidosPendientes pendientes</span>
                    <span><i class="bi bi-circle-fill text-warning me-1"></i>@pedidosEnCocina en cocina</span>
                    <span><i class="bi bi-circle-fill text-primary me-1"></i>@pedidosListos listos</span>
                </div>
            </div>
        </div>
    </div>

    <div class="chart-panel">
        <div class="analytics-card-title">
            <span><i class="bi bi-bar-chart-line text-success me-2"></i>Pedidos por hora</span>
            <small class="text-muted">Hoy</small>
        </div>
        <div class="home-mini-chart">
            <canvas id="pedidosHoraChart"></canvas>
        </div>
    </div>
</div>

<div class="card surface-card p-0">
    <div class="card-header bg-transparent border-bottom px-3 py-3 d-flex align-items-center gap-2">
        <i class="bi bi-activity text-warning"></i>
        <span class="fw-bold">Pedidos activos recientes</span>
        @if (ultimosPedidos.Count > 0)
        {
            <span class="badge bg-warning text-dark ms-auto">@ultimosPedidos.Count</span>
        }
    </div>

    @if (ultimosPedidos.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <span>No hay pedidos activos en este momento.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:70px">#</th>
                        <th>Mesa</th>
                        <th>Mozo</th>
                        <th>Estado</th>
                        <th class="text-end">Total</th>
                        <th class="text-end" style="width:80px">Accion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in ultimosPedidos)
                    {
                        var estadoClass = p.Estado switch {
                            "Pendiente" => "status-pending",
                            "EnCocina" => "status-cooking",
                            "Listo" => "status-ready",
                            "Entregado" => "status-delivered",
                            "Cancelado" => "status-cancelled",
                            _ => "status-pending"
                        };
                        <tr>
                            <td class="fw-bold text-muted small">#@p.Id</td>
                            <td><i class="bi bi-table me-1 text-secondary"></i>@p.MesaNumero</td>
                            <td class="small">@p.UsuarioNombre</td>
                            <td><span class="status-pill @estadoClass">@p.Estado</span></td>
                            <td class="text-end fw-semibold text-success small">S/ @p.Total.ToString("F2")</td>
                            <td class="text-end">
                                <a asp-controller="Pedido" asp-action="Detalle" asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-primary action-btn" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-3 py-2 border-top">
            <a asp-controller="Pedido" asp-action="Index" class="text-decoration-none small text-muted">
                Ver todos los pedidos <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
    const pedidosHora = @Html.Raw(JsonSerializer.Serialize(pedidosPorHora));
    const pedidosHoraLabels = pedidosHora.length ? pedidosHora.map(x => x.Hora) : ['Sin datos'];
    const pedidosHoraValues = pedidosHora.length ? pedidosHora.map(x => x.Cantidad) : [0];

    if (window.Chart && document.getElementById('pedidosHoraChart')) {
        new Chart(document.getElementById('pedidosHoraChart'), {
            type: 'bar',
            data: {
                labels: pedidosHoraLabels,
                datasets: [{
                    data: pedidosHoraValues,
                    backgroundColor: '#059669',
                    borderRadius: 8,
                    maxBarThickness: 34
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#64748b' } },
                    y: { beginAtZero: true, precision: 0, grid: { color: '#eef2f7' }, ticks: { color: '#64748b' } }
                }
            }
        });
    }

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/pedidos")
        .withAutomaticReconnect()
        .build();

    connection.on("NuevoPedido", () => location.reload());
    connection.on("EstadoPedidoActualizado", () => location.reload());
    connection.on("EstadoMesaActualizado", () => location.reload());

    connection.start().catch(err => console.error("SignalR:", err));
</script>
}


