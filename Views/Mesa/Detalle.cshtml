@model AppWebSistemaComandasDigital.Dtos.MesaDTO
@using AppWebSistemaComandasDigital.Dtos
@{
    ViewData["Title"] = $"Mesa {Model.Numero}";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var colorEstado = Model.Estado switch {
        "Libre"     => "success",
        "Ocupada"   => "danger",
        "Reservada" => "warning",
        _           => "secondary"
    };

    var pedidosActivos = ViewBag.PedidosActivos as List<PedidoDTO> ?? [];
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <div>
        <h3 class="fw-bold mb-0">Mesa @Model.Numero</h3>
        <p class="text-muted mb-0 small">Detalle e información de la mesa</p>
    </div>
</div>

<div class="row g-4">
    <!-- ── Info de la mesa ─────────────────────────────────────── -->
    <div class="col-md-4">
        <div class="card text-center p-4 mb-3">
            <i class="bi bi-table fs-1 text-secondary mb-3"></i>
            <h2 class="fw-bold">Mesa @Model.Numero</h2>
            <span class="badge bg-@colorEstado fs-6 px-3 py-2 mb-3">@Model.Estado</span>
            <p class="text-muted small mb-0">
                <i class="bi bi-people me-1"></i>Capacidad: <strong>@Model.Capacidad personas</strong>
            </p>
        </div>

        <!-- Acciones rápidas -->
        <div class="card p-3">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-lightning text-warning me-2"></i>Acciones rápidas
            </h6>
            @if (Model.Estado == "Libre")
            {
                <a asp-controller="Pedido" asp-action="Crear"
                   asp-route-mesaId="@Model.Id"
                   class="btn btn-success w-100 mb-2">
                    <i class="bi bi-plus-circle me-2"></i>Crear pedido
                </a>
            }
            else if (Model.Estado == "Ocupada")
            {
                <p class="text-muted small mb-2">
                    <i class="bi bi-info-circle me-1"></i>
                    Mesa ocupada — @pedidosActivos.Count pedido(s) activo(s).
                </p>
            }
            <a asp-action="Index" class="btn btn-outline-secondary w-100">
                <i class="bi bi-grid me-2"></i>Mapa de mesas
            </a>
        </div>
    </div>

    <!-- ── Pedidos activos ─────────────────────────────────────── -->
    <div class="col-md-8">
        <div class="card p-0">
            <div class="card-header bg-transparent border-bottom px-3 py-3 d-flex align-items-center gap-2">
                <i class="bi bi-list-check text-warning"></i>
                <span class="fw-bold">Pedidos activos</span>
                @if (pedidosActivos.Count > 0)
                {
                    <span class="badge bg-warning text-dark ms-auto">@pedidosActivos.Count</span>
                }
            </div>

            @if (pedidosActivos.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                    No hay pedidos activos en esta mesa.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:60px">#</th>
                                <th>Mozo</th>
                                <th>Estado</th>
                                <th class="text-end">Total</th>
                                <th style="width:80px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in pedidosActivos)
                            {
                                var badgeEstado = p.Estado switch {
                                    "Pendiente" => "secondary",
                                    "EnCocina"  => "warning",
                                    "Listo"     => "primary",
                                    _           => "secondary"
                                };
                                <tr>
                                    <td class="fw-bold text-muted">#@p.Id</td>
                                    <td>
                                        <i class="bi bi-person me-1 text-secondary"></i>@p.UsuarioNombre
                                    </td>
                                    <td>
                                        <span class="badge bg-@badgeEstado">@p.Estado</span>
                                    </td>
                                    <td class="text-end fw-semibold text-success">
                                        S/ @p.Total.ToString("F2")
                                    </td>
                                    <td class="text-end">
                                        <a asp-controller="Pedido" asp-action="Detalle"
                                           asp-route-id="@p.Id"
                                           class="btn btn-sm btn-outline-primary action-btn" title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold small">TOTAL MESA</td>
                                <td class="text-end fw-bold text-success">
                                    S/ @pedidosActivos.Sum(p => p.Total).ToString("F2")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
