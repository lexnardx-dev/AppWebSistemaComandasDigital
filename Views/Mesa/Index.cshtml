@model IEnumerable<AppWebSistemaComandasDigital.Dtos.MesaDTO>
@{
    ViewData["Title"] = "Mesas";
    var mesas = Model.ToList();
    var libres = mesas.Count(m => m.Estado == "Libre");
    var ocupadas = mesas.Count(m => m.Estado == "Ocupada");
    var reservadas = mesas.Count(m => m.Estado == "Reservada");
}

<div class="page-heading">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-grid-3x3-gap text-primary me-2"></i>Mesas</h3>
        <p class="page-subtitle">Estado operativo del salon en tiempo real</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <span class="status-pill status-delivered">Libre</span>
        <span class="status-pill status-cancelled">Ocupada</span>
        <span class="status-pill status-cooking">Reservada</span>
    </div>
</div>

<div class="mesa-summary">
    <div class="mesa-summary-card">
        <span>Libres</span>
        <strong>@libres</strong>
    </div>
    <div class="mesa-summary-card">
        <span>Ocupadas</span>
        <strong>@ocupadas</strong>
    </div>
    <div class="mesa-summary-card">
        <span>Reservadas</span>
        <strong>@reservadas</strong>
    </div>
</div>

<div class="row g-3" id="gridMesas">
    @foreach (var mesa in mesas)
    {
        var estiloCard = mesa.Estado switch {
            "Libre"     => "mesa-libre",
            "Ocupada"   => "mesa-ocupada",
            "Reservada" => "mesa-reservada",
            _           => ""
        };
        var estadoClass = mesa.Estado switch {
            "Libre"     => "status-delivered",
            "Ocupada"   => "status-cancelled",
            "Reservada" => "status-cooking",
            _           => "status-pending"
        };
        var dotClass = mesa.Estado switch {
            "Libre"     => "bg-success",
            "Ocupada"   => "bg-danger",
            "Reservada" => "bg-warning",
            _           => "bg-secondary"
        };
        <div class="col-6 col-md-4 col-lg-3 col-xxl-2">
            <a asp-action="Detalle" asp-route-id="@mesa.Id" class="text-decoration-none">
                <div class="card mesa-card @estiloCard h-100">
                    <div class="card-body d-flex flex-column justify-content-between py-3">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="mesa-state-dot @dotClass"></span>
                            <i class="bi bi-table fs-4 text-secondary"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1 text-dark">Mesa @mesa.Numero</h5>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-people me-1"></i>@mesa.Capacidad personas
                            </p>
                            <span class="status-pill @estadoClass">@mesa.Estado</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (!mesas.Any())
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle me-2"></i>No hay mesas registradas aun.
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/pedidos")
        .withAutomaticReconnect()
        .build();

    connection.on("EstadoMesaActualizado", () => location.reload());
    connection.start().catch(err => console.error("SignalR error:", err));
</script>
}