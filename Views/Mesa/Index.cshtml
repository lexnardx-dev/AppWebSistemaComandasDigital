@model IEnumerable<AppWebSistemaComandasDigital.Dtos.MesaDTO>
@{
    ViewData["Title"] = "Mesas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-grid-3x3-gap text-primary me-2"></i>Mesas</h3>
        <p class="text-muted mb-0 small">Estado actual de todas las mesas</p>
    </div>
    <div class="d-flex gap-2">
        <span class="badge bg-success px-3 py-2"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>Libre</span>
        <span class="badge bg-danger px-3 py-2"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>Ocupada</span>
        <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>Reservada</span>
    </div>
</div>

<div class="row g-3" id="gridMesas">
    @foreach (var mesa in Model)
    {
        var estiloCard = mesa.Estado switch {
            "Libre"     => "mesa-libre",
            "Ocupada"   => "mesa-ocupada",
            "Reservada" => "mesa-reservada",
            _           => ""
        };
        var colorEstado = mesa.Estado switch {
            "Libre"     => "success",
            "Ocupada"   => "danger",
            "Reservada" => "warning",
            _           => "secondary"
        };
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-action="Detalle" asp-route-id="@mesa.Id" class="text-decoration-none">
                <div class="card mesa-card @estiloCard h-100">
                    <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-4">
                        <i class="bi bi-table fs-2 text-secondary mb-2"></i>
                        <h5 class="fw-bold mb-1">Mesa @mesa.Numero</h5>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-people me-1"></i>@mesa.Capacidad personas
                        </p>
                        <span class="badge bg-@colorEstado">@mesa.Estado</span>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle me-2"></i>No hay mesas registradas aún.
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    // Conexión SignalR — actualiza estado de mesas en tiempo real
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/pedidos")
        .withAutomaticReconnect()
        .build();

    connection.on("EstadoMesaActualizado", (data) => {
        // Recargar página para reflejar cambio de estado
        location.reload();
    });

    connection.start().catch(err => console.error("SignalR error:", err));
</script>
}
