@model AppWebSistemaComandasDigital.Dtos.PedidoDTO
@{
    ViewData["Title"] = $"Pedido #{Model.Id}";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var colorEstado = Model.Estado switch {
        "Pendiente" => "secondary",
        "EnCocina"  => "warning",
        "Listo"     => "primary",
        "Entregado" => "success",
        "Cancelado" => "danger",
        _           => "secondary"
    };

    // Estados posibles para el dropdown
    var estados = new[] { "Pendiente", "EnCocina", "Listo", "Entregado", "Cancelado" };

    // Pedido cerrado = no se puede cambiar estado
    var cerrado = Model.Estado is "Entregado" or "Cancelado";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <div>
        <h3 class="fw-bold mb-0">
            Pedido <span class="text-muted">#@Model.Id</span>
        </h3>
        <p class="text-muted mb-0 small">
            <i class="bi bi-table me-1"></i>Mesa @Model.MesaNumero
            &nbsp;·&nbsp;
            <i class="bi bi-clock me-1"></i>@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
        </p>
    </div>
    <span class="badge bg-@colorEstado fs-6 ms-auto px-3 py-2">@Model.Estado</span>
</div>

<div class="row g-4">
    <!-- ── Panel lateral ──────────────────────────────────────── -->
    <div class="col-md-4">
        <!-- Info general -->
        <div class="card p-3 mb-3">
            <h6 class="fw-bold mb-3">
                <i class="bi bi-info-circle text-info me-2"></i>Información
            </h6>
            <ul class="list-unstyled mb-0 small">
                <li class="mb-2">
                    <i class="bi bi-table me-2 text-secondary"></i>
                    <strong>Mesa:</strong> @Model.MesaNumero
                </li>
                <li class="mb-2">
                    <i class="bi bi-person me-2 text-secondary"></i>
                    <strong>Mozo:</strong> @Model.UsuarioNombre
                </li>
                <li class="mb-2">
                    <i class="bi bi-clock me-2 text-secondary"></i>
                    <strong>Fecha:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                </li>
                <li class="mb-2">
                    <i class="bi bi-hash me-2 text-secondary"></i>
                    <strong>Platos:</strong> @Model.Detalles.Count item(s)
                </li>
                @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                    <li>
                        <i class="bi bi-chat-left-text me-2 text-secondary"></i>
                        <strong>Obs.:</strong> @Model.Observaciones
                    </li>
                }
            </ul>
        </div>

        <!-- Cambiar estado -->
        @if (!cerrado)
        {
            <div class="card p-3">
                <h6 class="fw-bold mb-3">
                    <i class="bi bi-arrow-repeat text-warning me-2"></i>Cambiar estado
                </h6>
                <select id="selectEstado" class="form-select form-select-sm mb-2">
                    @foreach (var est in estados)
                    {
                        if (est == Model.Estado)
                        {
                            <option value="@est" selected>@est</option>
                        }
                        else
                        {
                            <option value="@est">@est</option>
                        }
                    }
                </select>
                <button id="btnActualizarEstado" class="btn btn-warning btn-sm w-100">
                    <i class="bi bi-check2 me-1"></i>Actualizar estado
                </button>
                <div id="msgEstado" class="small mt-2 d-none"></div>
            </div>
        }
        else
        {
            <div class="card p-3 bg-light">
                <p class="small text-muted mb-0 text-center">
                    <i class="bi bi-lock me-1"></i>
                    Pedido <strong>@Model.Estado</strong> — no se puede modificar.
                </p>
            </div>
        }
    </div>

    <!-- ── Detalles del pedido ─────────────────────────────────── -->
    <div class="col-md-8">
        <div class="card p-0">
            <div class="card-header bg-transparent border-bottom px-3 py-3 d-flex align-items-center gap-2">
                <i class="bi bi-egg-fried text-warning"></i>
                <span class="fw-bold">Platos del pedido</span>
                <span class="badge bg-secondary ms-auto">@Model.Detalles.Count item(s)</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Plato</th>
                            <th class="text-center" style="width:70px">Cant.</th>
                            <th class="text-end" style="width:110px">P. Unit.</th>
                            <th class="text-end" style="width:110px">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Detalles)
                        {
                            <tr>
                                <td>
                                    <span class="fw-semibold">@d.PlatoNombre</span>
                                    @if (!string.IsNullOrEmpty(d.Notas))
                                    {
                                        <br />
                                        <small class="text-muted">
                                            <i class="bi bi-chat-left-dots me-1"></i>@d.Notas
                                        </small>
                                    }
                                </td>
                                <td class="text-center">@d.Cantidad</td>
                                <td class="text-end text-muted small">S/ @d.PrecioUnitario.ToString("F2")</td>
                                <td class="text-end fw-semibold">S/ @d.Subtotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-success">
                            <td colspan="3" class="fw-bold text-end">TOTAL</td>
                            <td class="fw-bold text-end fs-5 text-success">
                                S/ @Model.Total.ToString("F2")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const btn = document.getElementById('btnActualizarEstado');
    if (btn) {
        btn.addEventListener('click', async () => {
            const estado  = document.getElementById('selectEstado').value;
            const msgDiv  = document.getElementById('msgEstado');
            btn.disabled  = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Actualizando...';

            try {
                const res  = await fetch('/api/pedidos/@Model.Id/estado', {
                    method:  'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ estado })
                });
                const data = await res.json();

                if (data.exitoso) {
                    location.reload();
                } else {
                    msgDiv.textContent = data.mensaje;
                    msgDiv.className   = 'small mt-2 text-danger';
                    btn.disabled       = false;
                    btn.innerHTML      = '<i class="bi bi-check2 me-1"></i>Actualizar estado';
                }
            } catch {
                msgDiv.textContent = 'Error de conexión.';
                msgDiv.className   = 'small mt-2 text-danger';
                btn.disabled       = false;
                btn.innerHTML      = '<i class="bi bi-check2 me-1"></i>Actualizar estado';
            }
        });
    }
</script>
}
