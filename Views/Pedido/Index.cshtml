@model IEnumerable<AppWebSistemaComandasDigital.Dtos.PedidoDTO>
@{
    ViewData["Title"] = "Pedidos activos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-list-check text-warning me-2"></i>Pedidos activos</h3>
        <p class="text-muted mb-0 small">Operaciones en curso: pendiente, en cocina y listo</p>
    </div>
    <a asp-action="Crear" class="btn btn-success">
        <i class="bi bi-plus-circle me-2"></i>Nuevo pedido
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table id="tablaPedidosActivos" class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Mesa</th>
                        <th>Mozo</th>
                        <th>Estado</th>
                        <th>Total</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaPedidos">
                    @foreach (var p in Model)
                    {
                        var badgeClass = $"badge-{p.Estado}";
                        <tr data-filter-row>
                            <td class="fw-bold">#@p.Id</td>
                            <td><i class="bi bi-table me-1"></i>Mesa @p.MesaNumero</td>
                            <td>@p.UsuarioNombre</td>
                            <td>
                                <span class="badge @badgeClass px-2 py-1">@p.Estado</span>
                            </td>
                            <td class="fw-bold text-success">S/ @p.Total.ToString("F2")</td>
                            <td class="text-muted small">
                                @p.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                <a asp-action="Detalle" asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-primary action-btn" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay pedidos activos.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div id="paginacionPedidosActivos"></div>
    </div>
</div>

@section Scripts {
<script>
    crearPaginacionTabla({
        tableId: 'tablaPedidosActivos',
        paginationId: 'paginacionPedidosActivos',
        pageSize: 15
    });

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/pedidos")
        .withAutomaticReconnect()
        .build();

    connection.on("EstadoPedidoActualizado", (data) => {
        location.reload();
    });

    connection.on("NuevoPedido", (pedido) => {
        location.reload();
    });

    connection.start().catch(err => console.error("SignalR:", err));
</script>
}
