@model AppWebSistemaComandasDigital.Dtos.PerfilViewDTO
@{
    ViewData["Title"] = "Perfil";
    var inicial = Model.Usuario.Nombre.FirstOrDefault().ToString().ToUpper();
}

<div class="page-heading">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-person-circle text-primary me-2"></i>Perfil</h3>
        <p class="page-subtitle">Cuenta, avatar y seguridad personal</p>
    </div>
</div>

<div class="profile-grid">
    <section class="card profile-summary-card">
        <div class="profile-identity">
            <div class="profile-avatar-wrap">
                @if (!string.IsNullOrWhiteSpace(Model.Usuario.ImagenUrl))
                {
                    <img src="@Model.Usuario.ImagenUrl" alt="Avatar de @Model.Usuario.Nombre" class="profile-avatar-img" onerror="this.classList.add('d-none');this.nextElementSibling.classList.remove('d-none');" />
                    <div class="profile-avatar-fallback d-none">@inicial</div>
                }
                else
                {
                    <div class="profile-avatar-fallback">@inicial</div>
                }
            </div>
            <div class="profile-identity-main">
                <h4>@Model.Usuario.Nombre</h4>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="badge bg-warning text-dark">@Model.Usuario.Rol</span>
                    <span class="badge @(Model.Usuario.Activo ? "bg-success" : "bg-secondary")">
                        @(Model.Usuario.Activo ? "Activo" : "Inactivo")
                    </span>
                </div>
            </div>
        </div>

        <div class="profile-facts">
            <div>
                <span>Correo</span>
                <strong>@Model.Usuario.Email</strong>
            </div>
            <div>
                <span>Creación</span>
                <strong>@Model.Usuario.FechaCreacion.ToString("dd/MM/yyyy")</strong>
            </div>
            <div>
                <span>ID de usuario</span>
                <strong>#@Model.Usuario.Id</strong>
            </div>
        </div>
    </section>

    <section class="card profile-panel">
        <div class="profile-panel-header">
            <div>
                <h5><i class="bi bi-person-lines-fill text-primary me-2"></i>Editar perfil</h5>
                <p>Actualiza tu nombre visible y foto de cuenta.</p>
            </div>
        </div>

        <form asp-action="Actualizar" method="post" enctype="multipart/form-data" class="profile-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Editar.Nombre" class="form-label fw-semibold small">Nombre</label>
                    <input asp-for="Editar.Nombre" class="form-control" autocomplete="name" />
                    <span asp-validation-for="Editar.Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Editar.ImagenUrl" class="form-label fw-semibold small">URL de imagen</label>
                    <input asp-for="Editar.ImagenUrl" class="form-control" placeholder="https://..." id="perfilImagenUrl" />
                    <div class="form-text">Usa una URL directa y pública de imagen.</div>
                    <span asp-validation-for="Editar.ImagenUrl" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Editar.ImagenArchivo" class="form-label fw-semibold small">Subir imagen</label>
                    <input asp-for="Editar.ImagenArchivo" type="file" accept="image/png,image/jpeg,image/webp" class="form-control" id="perfilImagenArchivo" />
                    <div class="form-text">JPG, PNG o WebP. Máximo 5 MB. El bucket de Supabase debe ser público.</div>
                    <span asp-validation-for="Editar.ImagenArchivo" class="text-danger small"></span>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">
                        <i class="bi bi-check2 me-1"></i>Guardar perfil
                    </button>
                </div>
            </div>
        </form>
    </section>

    <section class="card profile-panel profile-security-panel">
        <div class="profile-panel-header">
            <div>
                <h5><i class="bi bi-shield-lock text-secondary me-2"></i>Cambiar contraseña</h5>
                <p>Usa mínimo 10 caracteres con mayúscula, minúscula, número y símbolo.</p>
            </div>
        </div>

        <form asp-action="CambiarPassword" method="post" class="profile-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Password.PasswordActual" class="form-label fw-semibold small">Contraseña actual</label>
                    <div class="input-group password-field">
                        <input asp-for="Password.PasswordActual" type="password" class="form-control" autocomplete="current-password" />
                        <button class="btn btn-outline-secondary password-toggle" type="button" title="Mostrar contraseña" aria-label="Mostrar contraseña">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password.PasswordActual" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Password.NuevaPassword" class="form-label fw-semibold small">Nueva contraseña</label>
                    <div class="input-group password-field">
                        <input asp-for="Password.NuevaPassword" type="password" class="form-control" autocomplete="new-password" id="nuevaPassword" />
                        <button class="btn btn-outline-secondary password-toggle" type="button" title="Mostrar contraseña" aria-label="Mostrar contraseña">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password.NuevaPassword" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Password.ConfirmarPassword" class="form-label fw-semibold small">Confirmar contraseña</label>
                    <div class="input-group password-field">
                        <input asp-for="Password.ConfirmarPassword" type="password" class="form-control" autocomplete="new-password" />
                        <button class="btn btn-outline-secondary password-toggle" type="button" title="Mostrar contraseña" aria-label="Mostrar contraseña">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password.ConfirmarPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="password-strength" aria-live="polite">
                <div class="password-strength-bar"><span id="passwordStrengthBar"></span></div>
                <small id="passwordStrengthText">Seguridad de contraseña pendiente.</small>
            </div>

            <button class="btn btn-primary" type="submit">
                <i class="bi bi-check2 me-1"></i>Actualizar contraseña
            </button>
        </form>
    </section>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.querySelectorAll('.password-toggle').forEach(button => {
            button.addEventListener('click', () => {
                const input = button.closest('.password-field').querySelector('input');
                const visible = input.type === 'text';
                input.type = visible ? 'password' : 'text';
                button.title = visible ? 'Mostrar contraseña' : 'Ocultar contraseña';
                button.setAttribute('aria-label', button.title);
                button.querySelector('i').className = visible ? 'bi bi-eye' : 'bi bi-eye-slash';
            });
        });

        const nuevaPassword = document.getElementById('nuevaPassword');
        const strengthBar = document.getElementById('passwordStrengthBar');
        const strengthText = document.getElementById('passwordStrengthText');

        function calcularFortaleza(value) {
            let score = 0;
            if (value.length >= 10) score++;
            if (/[a-z]/.test(value)) score++;
            if (/[A-Z]/.test(value)) score++;
            if (/[0-9]/.test(value)) score++;
            if (/[^A-Za-z0-9]/.test(value)) score++;
            return score;
        }

        nuevaPassword?.addEventListener('input', () => {
            const score = calcularFortaleza(nuevaPassword.value);
            const percent = Math.min(100, score * 20);
            strengthBar.style.width = `${percent}%`;
            strengthBar.className = score >= 5 ? 'strong' : score >= 3 ? 'medium' : 'weak';
            strengthText.textContent = score >= 5
                ? 'Contraseña fuerte.'
                : score >= 3
                    ? 'Contraseña media. Agrega más variedad.'
                    : 'Contraseña débil. Usa longitud, mayúscula, número y símbolo.';
        });
    </script>
}
