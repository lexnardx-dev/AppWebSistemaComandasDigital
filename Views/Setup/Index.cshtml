@model AppWebSistemaComandasDigital.Controllers.SetupViewModel
@{
    ViewData["Title"] = "Configuración inicial";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Setup — Sistema de Comandas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-wrapper">
    <div class="login-card card shadow-lg p-4">

        <div class="text-center mb-4">
            <i class="bi bi-shield-lock fs-1 text-success"></i>
            <h4 class="fw-bold mt-2 mb-0">Configuración inicial</h4>
            <p class="text-muted small">
                Crea la cuenta del administrador del sistema.<br />
                Esta página se desactivará automáticamente una vez completada.
            </p>
        </div>

        <div class="alert alert-warning py-2 small mb-3">
            <i class="bi bi-exclamation-triangle me-1"></i>
            <strong>Solo se puede usar una vez.</strong>
            Después de crear el admin, esta ruta quedará bloqueada.
        </div>

        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger small py-2 mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold">
                    <i class="bi bi-person me-1"></i>Nombre completo
                </label>
                <input asp-for="Nombre" class="form-control form-control-lg"
                       placeholder="Ej: Juan Pérez" autofocus />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">
                    <i class="bi bi-envelope me-1"></i>Correo electrónico
                </label>
                <input asp-for="Email" class="form-control form-control-lg"
                       placeholder="admin@tudominio.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">
                    <i class="bi bi-lock me-1"></i>Contraseña
                </label>
                <div class="input-group">
                    <input asp-for="Password" type="password" id="inputPass"
                           class="form-control form-control-lg"
                           placeholder="Mínimo 8 caracteres" />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="togglePass('inputPass', 'iconoPass')">
                        <i class="bi bi-eye" id="iconoPass"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmarPassword" class="form-label fw-semibold">
                    <i class="bi bi-lock-fill me-1"></i>Confirmar contraseña
                </label>
                <div class="input-group">
                    <input asp-for="ConfirmarPassword" type="password" id="inputPass2"
                           class="form-control form-control-lg"
                           placeholder="Repite la contraseña" />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="togglePass('inputPass2', 'iconoPass2')">
                        <i class="bi bi-eye" id="iconoPass2"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-success btn-lg fw-bold">
                    <i class="bi bi-check2-circle me-2"></i>Crear cuenta de administrador
                </button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-controller="Auth" asp-action="Login"
               class="text-muted small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>Volver al login
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icono = document.getElementById(iconId);
            const visible = input.type === 'text';
            input.type = visible ? 'password' : 'text';
            icono.className = visible ? 'bi bi-eye' : 'bi bi-eye-slash';
        }
    </script>
</body>
</html>
