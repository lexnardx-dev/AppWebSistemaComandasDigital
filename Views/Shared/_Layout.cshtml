@inject AppWebSistemaComandasDigital.Services.NotificacionService NotificacionService
@inject AppWebSistemaComandasDigital.Services.ConfiguracionRestauranteService ConfiguracionService
@inject AppWebSistemaComandasDigital.Services.UsuarioActualService UsuarioActualService
@functions {
    private static string ConVersion(string? url, DateTime version)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;
        var separador = url.Contains('?') ? "&" : "?";
        return $"{url}{separador}v={version.Ticks}";
    }
}
@{
    var configuracion = await ConfiguracionService.ObtenerAsync();
    var nombreRestaurante = string.IsNullOrWhiteSpace(configuracion.NombreRestaurante)
        ? "Comandas"
        : configuracion.NombreRestaurante;
    var logoMarca = ConVersion(configuracion.LogoUrl, configuracion.FechaActualizacion);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @nombreRestaurante</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="sc-body">

@{
    var ctrl        = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action      = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var area        = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var usuarioActual = await UsuarioActualService.ObtenerAsync();
    var userName    = usuarioActual?.Nombre ?? User.Identity?.Name ?? "Usuario";
    var userInitial = usuarioActual?.Inicial ?? (userName.Length > 0 ? userName[0].ToString().ToUpper() : "U");
    var rolActual   = usuarioActual?.Rol ?? User.FindFirst("rol_nombre")?.Value ?? "";
    var userImageUrl = usuarioActual?.ImagenUrl;
    var isAdmin     = User.HasClaim("rol_nombre", "Admin");
    var isCocina    = User.HasClaim("rol_nombre", "Cocina");
    var usuarioIdClaim = User.FindFirst("usuario_id")?.Value;
    var notificacionesNoLeidas = int.TryParse(usuarioIdClaim, out var usuarioId)
        ? await NotificacionService.ContarNoLeidasAsync(usuarioId)
        : 0;
}

<!-- ==========================================================
     SIDEBAR
     ========================================================== -->
<aside class="sc-sidebar" id="sidebar">

    <!-- Brand -->
    <div class="sc-sidebar-brand">
        <div class="sc-brand-icon">
            @if (!string.IsNullOrWhiteSpace(logoMarca))
            {
                <img src="@logoMarca" alt="@nombreRestaurante" class="sc-brand-logo" loading="lazy" />
            }
            else
            {
                <i class="bi bi-shop-window"></i>
            }
        </div>
        <div class="sc-brand-info">
            <div class="sc-brand-name">@nombreRestaurante</div>
            <div class="sc-brand-sub">Sistema POS</div>
        </div>
    </div>

    <!-- Navegación -->
    <nav class="sc-nav">

        <!-- -- GENERAL ---------------------------------------- -->
        <div class="sc-nav-section">
            <div class="sc-nav-label">General</div>
        </div>

        <a asp-area="" asp-controller="Home" asp-action="Index"
           class="sc-nav-item @(ctrl == "Home" ? "active" : "")">
            <div class="sc-nav-icon"><i class="bi bi-speedometer2"></i></div>
            <span>Inicio</span>
        </a>

        <div class="sc-nav-section">
            <div class="sc-nav-label">Operación</div>
        </div>

        <a asp-area="" asp-controller="Pedido" asp-action="Index"
           class="sc-nav-item @(ctrl == "Pedido" && action == "Index" ? "active" : "")">
            <div class="sc-nav-icon"><i class="bi bi-receipt-cutoff"></i></div>
            <span>Pedidos activos</span>
        </a>

        <a asp-area="" asp-controller="Pedido" asp-action="Crear"
           class="sc-nav-item @(ctrl == "Pedido" && action == "Crear" ? "active" : "")">
            <div class="sc-nav-icon"><i class="bi bi-plus-circle"></i></div>
            <span>Nuevo pedido</span>
        </a>

        <a asp-area="" asp-controller="Mesa" asp-action="Index"
           class="sc-nav-item @(ctrl == "Mesa" ? "active" : "")">
            <div class="sc-nav-icon"><i class="bi bi-grid-3x3-gap"></i></div>
            <span>Mesas</span>
        </a>

        <a asp-area="" asp-controller="Notificaciones" asp-action="Index"
           class="sc-nav-item @(ctrl == "Notificaciones" ? "active" : "")">
            <div class="sc-nav-icon"><i class="bi bi-bell"></i></div>
            <span>Notificaciones</span>
            @if (notificacionesNoLeidas > 0)
            {
                <span class="badge bg-warning text-dark ms-auto" style="font-size:.68rem">@notificacionesNoLeidas</span>
            }
        </a>
        <!-- -- OPERACIONES ------------------------------------- -->
        @if (isAdmin || isCocina)
        {

            <a asp-area="Cocina" asp-controller="Cocina" asp-action="Index"
               class="sc-nav-item @(area == "Cocina" ? "active" : "")">
                <div class="sc-nav-icon"><i class="bi bi-fire"></i></div>
                <span>Cocina (KDS)</span>
            </a>

            <a asp-area="" asp-controller="Pedido" asp-action="Historial"
               class="sc-nav-item @(ctrl == "Pedido" && action == "Historial" ? "active" : "")">
                <div class="sc-nav-icon"><i class="bi bi-clock-history"></i></div>
                <span>Historial pedidos</span>
            </a>

            @if (isAdmin)
            {
                <a asp-area="Admin" asp-controller="Ventas" asp-action="Index"
                   class="sc-nav-item @(ctrl == "Ventas" ? "active" : "")">
                    <div class="sc-nav-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <span>Ventas</span>
                </a>
            }
        }

        <!-- -- GESTIÓN (solo Admin) ---------------------------- -->
        @if (isAdmin)
        {
            <div class="sc-nav-section">
                <div class="sc-nav-label">Gestión</div>
            </div>

            <a asp-area="Admin" asp-controller="Plato" asp-action="Index"
               class="sc-nav-item @(ctrl == "Plato" ? "active" : "")">
                <div class="sc-nav-icon"><i class="bi bi-egg-fried"></i></div>
                <span>Platos</span>
            </a>

            <a asp-area="Admin" asp-controller="Categoria" asp-action="Index"
               class="sc-nav-item @(ctrl == "Categoria" ? "active" : "")">
                <div class="sc-nav-icon"><i class="bi bi-tags"></i></div>
                <span>Categorías</span>
            </a>

            <a asp-area="Admin" asp-controller="MesaAdmin" asp-action="Index"
               class="sc-nav-item @(ctrl == "MesaAdmin" ? "active" : "")">
                <div class="sc-nav-icon"><i class="bi bi-layout-text-sidebar-reverse"></i></div>
                <span>Gestión de mesas</span>
            </a>

            <a asp-area="Admin" asp-controller="UsuarioAdmin" asp-action="Index"
               class="sc-nav-item @(ctrl == "UsuarioAdmin" ? "active" : "")">
                <div class="sc-nav-icon"><i class="bi bi-people"></i></div>
                <span>Usuarios</span>
            </a>

            <!-- -- SISTEMA ------------------------------------- -->
            <div class="sc-nav-section">
                <div class="sc-nav-label">Sistema</div>
            </div>

            <a asp-area="Admin" asp-controller="Configuracion" asp-action="Index"
               class="sc-nav-item @(ctrl == "Configuracion" ? "active" : "")">
                <div class="sc-nav-icon"><i class="bi bi-sliders"></i></div>
                <span>Configuración</span>
            </a>

        }

    </nav>

    <!-- Footer -->
    <div class="sc-sidebar-footer">

        <div class="sc-user-info">
            <div class="sc-user-avatar" aria-hidden="true">
                @if (!string.IsNullOrWhiteSpace(userImageUrl))
                {
                    <img src="@userImageUrl" alt="" class="sc-user-avatar-img" loading="lazy" onerror="this.classList.add('d-none');this.nextElementSibling.classList.remove('d-none');" />
                    <span class="d-none">@userInitial</span>
                }
                else
                {
                    @userInitial
                }
            </div>
            <div class="sc-user-details">
                <div class="sc-user-name">@userName</div>
                <div class="sc-user-role">@rolActual</div>
            </div>
            <a asp-area="" asp-controller="Perfil" asp-action="Index"
               class="sc-footer-action @(ctrl == "Perfil" ? "active" : "")"
               title="Perfil" aria-label="Perfil">
                <i class="bi bi-person-gear"></i>
            </a>
            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post" class="sc-logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="sc-logout-btn" title="Cerrar sesión" aria-label="Cerrar sesión">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </div>

    </div>

</aside>

<!-- ==========================================================
     MAIN
     ========================================================== -->
<div class="sc-main" id="scMain">

    <!-- TOPBAR -->
    <header class="sc-topbar">
        <button class="sc-toggle-btn" id="sidebarToggle" title="Menú" aria-label="Alternar menú lateral" type="button">
            <i class="bi bi-list" style="font-size:1.25rem"></i>
        </button>

        <div class="sc-topbar-title">@ViewData["Title"]</div>

        <div class="sc-topbar-right">
            <span class="sc-clock" id="reloj"></span>
            <div class="sc-user-badge">
                <div class="sc-topbar-avatar" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(userImageUrl))
                    {
                        <img src="@userImageUrl" alt="" class="sc-topbar-avatar-img" loading="lazy" onerror="this.classList.add('d-none');this.nextElementSibling.classList.remove('d-none');" />
                        <span class="d-none">@userInitial</span>
                    }
                    else
                    {
                        @userInitial
                    }
                </div>
                <span>@userName</span>
                <span class="badge bg-warning text-dark ms-1" style="font-size:.68rem">@rolActual</span>
            </div>
        </div>
    </header>

    <!-- ALERTAS + CONTENIDO -->
    <div class="sc-content">
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3 alert-auto"
                 role="alert" id="alertaExito">
                <i class="bi bi-check-circle me-2"></i>@TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="@Url.Content("~/js/site.js")"></script>
<script>
    // Reloj
    const reloj = document.getElementById('reloj');
    if (reloj) {
        const tick = () => reloj.textContent = new Date().toLocaleTimeString('es-PE');
        tick(); setInterval(tick, 1000);
    }

    // Toggle sidebar
    const sidebar = document.getElementById('sidebar');
    const scMain = document.getElementById('scMain');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const isMobileLayout = () => window.matchMedia('(max-width: 768px)').matches;

    sidebarToggle.addEventListener('click', () => {
        if (isMobileLayout()) {
            sidebar.classList.toggle('mobile-open');
            document.body.classList.toggle('sc-sidebar-open', sidebar.classList.contains('mobile-open'));
            return;
        }

        sidebar.classList.toggle('collapsed');
        scMain.classList.toggle('expanded');
    });

    document.querySelectorAll('.sc-nav-item').forEach(item => {
        item.addEventListener('click', () => {
            if (!isMobileLayout()) return;
            sidebar.classList.remove('mobile-open');
            document.body.classList.remove('sc-sidebar-open');
        });
    });

    window.addEventListener('resize', () => {
        if (!isMobileLayout()) {
            sidebar.classList.remove('mobile-open');
            document.body.classList.remove('sc-sidebar-open');
        }
    });

    // Auto-cerrar alerta de éxito con fade suave - 3 segundos
    const alertaExito = document.getElementById('alertaExito');
    if (alertaExito) {
        setTimeout(() => {
            alertaExito.style.transition = 'opacity 0.6s ease';
            alertaExito.style.opacity = '0';
            setTimeout(() => bootstrap.Alert.getOrCreateInstance(alertaExito).close(), 600);
        }, 3000);
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
