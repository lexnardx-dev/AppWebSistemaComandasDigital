<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Comandas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="sc-body">

@{
    var ctrl        = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action      = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var area        = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var userName    = User.Identity?.Name ?? "Usuario";
    var userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
    var rolActual   = User.FindFirst("rol_nombre")?.Value ?? "";
    var isAdmin     = User.HasClaim("rol_nombre", "Admin");
    var isCocina    = User.HasClaim("rol_nombre", "Cocina");
}

<!-- ══════════════════════════════════════════════════════════
     SIDEBAR
     ══════════════════════════════════════════════════════════ -->
<aside class="sc-sidebar" id="sidebar">

    <!-- Brand -->
    <div class="sc-sidebar-brand">
        <div class="sc-brand-icon">
            <i class="ri-restaurant-2-line"></i>
        </div>
        <div class="sc-brand-info">
            <div class="sc-brand-name">Comandas</div>
            <div class="sc-brand-sub">Sistema POS</div>
        </div>
    </div>

    <!-- Navegación -->
    <nav class="sc-nav">

        <!-- ── GENERAL ──────────────────────────────────────── -->
        <div class="sc-nav-section">
            <div class="sc-nav-label">General</div>
        </div>

        <a asp-area="" asp-controller="Home" asp-action="Index"
           class="sc-nav-item @(ctrl == "Home" ? "active" : "")">
            <div class="sc-nav-icon"><i class="ri-home-5-line"></i></div>
            <span>Inicio</span>
        </a>

        <a asp-area="" asp-controller="Pedido" asp-action="Index"
           class="sc-nav-item @(ctrl == "Pedido" && action == "Index" ? "active" : "")">
            <div class="sc-nav-icon"><i class="ri-file-list-3-line"></i></div>
            <span>Pedidos</span>
        </a>

        <a asp-area="" asp-controller="Pedido" asp-action="Crear"
           class="sc-nav-item @(ctrl == "Pedido" && action == "Crear" ? "active" : "")">
            <div class="sc-nav-icon"><i class="ri-add-circle-line"></i></div>
            <span>Nuevo pedido</span>
        </a>

        <a asp-area="" asp-controller="Mesa" asp-action="Index"
           class="sc-nav-item @(ctrl == "Mesa" ? "active" : "")">
            <div class="sc-nav-icon"><i class="ri-layout-grid-line"></i></div>
            <span>Mesas</span>
        </a>

        <!-- ── OPERACIONES ───────────────────────────────────── -->
        @if (isAdmin || isCocina)
        {
            <div class="sc-nav-section">
                <div class="sc-nav-label">Operaciones</div>
            </div>

            <a asp-area="Cocina" asp-controller="Cocina" asp-action="Index"
               class="sc-nav-item @(area == "Cocina" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-fire-line"></i></div>
                <span>Cocina (KDS)</span>
            </a>

            <a asp-area="" asp-controller="Pedido" asp-action="Historial"
               class="sc-nav-item @(ctrl == "Pedido" && action == "Historial" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-history-line"></i></div>
                <span>Historial pedidos</span>
            </a>

            @if (isAdmin)
            {
                <a asp-area="Admin" asp-controller="Ventas" asp-action="Index"
                   class="sc-nav-item @(ctrl == "Ventas" ? "active" : "")">
                    <div class="sc-nav-icon"><i class="ri-bar-chart-2-line"></i></div>
                    <span>Ventas</span>
                </a>
            }
        }

        <!-- ── GESTIÓN (solo Admin) ──────────────────────────── -->
        @if (isAdmin)
        {
            <div class="sc-nav-section">
                <div class="sc-nav-label">Gestión</div>
            </div>

            <a asp-area="Admin" asp-controller="Plato" asp-action="Index"
               class="sc-nav-item @(ctrl == "Plato" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-bowl-line"></i></div>
                <span>Platos</span>
            </a>

            <a asp-area="Admin" asp-controller="Categoria" asp-action="Index"
               class="sc-nav-item @(ctrl == "Categoria" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-price-tag-3-line"></i></div>
                <span>Categorías</span>
            </a>

            <a asp-area="Admin" asp-controller="MesaAdmin" asp-action="Index"
               class="sc-nav-item @(ctrl == "MesaAdmin" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-table-line"></i></div>
                <span>Gestión de mesas</span>
            </a>

            <a asp-area="Admin" asp-controller="UsuarioAdmin" asp-action="Index"
               class="sc-nav-item @(ctrl == "UsuarioAdmin" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-team-line"></i></div>
                <span>Usuarios</span>
            </a>

            <!-- ── SISTEMA ───────────────────────────────────── -->
            <div class="sc-nav-section">
                <div class="sc-nav-label">Sistema</div>
            </div>

            <a asp-area="Admin" asp-controller="Configuracion" asp-action="Index"
               class="sc-nav-item @(ctrl == "Configuracion" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-settings-4-line"></i></div>
                <span>Configuración</span>
            </a>

            <a asp-area="" asp-controller="Perfil" asp-action="Index"
               class="sc-nav-item @(ctrl == "Perfil" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-user-settings-line"></i></div>
                <span>Perfil</span>
            </a>

            <a asp-area="" asp-controller="Notificaciones" asp-action="Index"
               class="sc-nav-item @(ctrl == "Notificaciones" ? "active" : "")">
                <div class="sc-nav-icon"><i class="ri-notification-3-line"></i></div>
                <span>Notificaciones</span>
            </a>
        }

    </nav>

    <!-- Footer -->
    <div class="sc-sidebar-footer">

        <div class="sc-user-info">
            <div class="sc-user-avatar">@userInitial</div>
            <div class="sc-user-details">
                <div class="sc-user-name">@userName</div>
                <div class="sc-user-role">@rolActual</div>
            </div>
            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post" class="sc-logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="sc-logout-btn" title="Cerrar sesión" aria-label="Cerrar sesión">
                    <i class="ri-logout-box-r-line"></i>
                </button>
            </form>
        </div>

    </div>

</aside>

<!-- ══════════════════════════════════════════════════════════
     MAIN
     ══════════════════════════════════════════════════════════ -->
<div class="sc-main" id="scMain">

    <!-- TOPBAR -->
    <header class="sc-topbar">
        <button class="sc-toggle-btn" id="sidebarToggle" title="Menú">
            <i class="ri-menu-line" style="font-size:1.15rem"></i>
        </button>

        <div class="sc-topbar-title">@ViewData["Title"]</div>

        <div class="sc-topbar-right">
            <span class="sc-clock" id="reloj"></span>
            <div class="sc-user-badge">
                <div class="sc-topbar-avatar">@userInitial</div>
                <span>@userName</span>
                <span class="badge bg-warning text-dark ms-1" style="font-size:.68rem">@rolActual</span>
            </div>
        </div>
    </header>

    <!-- ALERTAS + CONTENIDO -->
    <div class="sc-content">
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3 alert-auto"
                 role="alert" id="alertaExito">
                <i class="ri-checkbox-circle-line me-2"></i>@TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="ri-error-warning-line me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    // Reloj
    const reloj = document.getElementById('reloj');
    if (reloj) {
        const tick = () => reloj.textContent = new Date().toLocaleTimeString('es-PE');
        tick(); setInterval(tick, 1000);
    }

    // Toggle sidebar
    document.getElementById('sidebarToggle').addEventListener('click', () => {
        document.getElementById('sidebar').classList.toggle('collapsed');
        document.getElementById('scMain').classList.toggle('expanded');
    });

    // Auto-cerrar alerta de éxito con fade suave — 3 segundos
    const alertaExito = document.getElementById('alertaExito');
    if (alertaExito) {
        setTimeout(() => {
            alertaExito.style.transition = 'opacity 0.6s ease';
            alertaExito.style.opacity = '0';
            setTimeout(() => bootstrap.Alert.getOrCreateInstance(alertaExito).close(), 600);
        }, 3000);
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
